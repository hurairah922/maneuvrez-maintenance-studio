<?xml version="1.0"?>
<ruleset name="Maneuvrez Maintenance Studio">
	<description>WordPress Coding Standards for Maneuvrez Maintenance Studio.</description>

	<file>maneuvrez-maintenance-studio.php</file>
	<file>includes</file>
	<file>public/templates</file>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<rule ref="WordPress-Core" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-Extra" />
</ruleset>
