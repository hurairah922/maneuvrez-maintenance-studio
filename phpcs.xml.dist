<?xml version="1.0"?>
<ruleset name="Maintenance Mode Studio">
	<description>WordPress Coding Standards for Maintenance Mode Studio.</description>

	<file>maintenance-mode-studio.php</file>
	<file>includes</file>
	<file>public/templates</file>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<rule ref="WordPress-Core" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-Extra" />
</ruleset>
